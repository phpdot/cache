{
    "name": "phpdot/cache",
    "description": "PSR-16 cache with pluggable drivers. Redis, File, Array, APCu, Null. remember() pattern. Standalone.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Omar Hamdan",
            "email": "omar@phpdot.com"
        }
    ],
    "keywords": ["cache", "psr-16", "redis", "file", "apcu", "simple-cache"],
    "require": {
        "php": ">=8.3",
        "psr/simple-cache": "^3.0"
    },
    "provide": {
        "psr/simple-cache-implementation": "3.0"
    },
    "suggest": {
        "ext-redis": "Required for RedisDriver",
        "ext-apcu": "Required for ApcuDriver",
        "ext-igbinary": "Faster serialization (auto-detected)"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^2.0",
        "phpstan/phpstan-strict-rules": "^2.0",
        "friendsofphp/php-cs-fixer": "^3.94"
    },
    "autoload": {
        "psr-4": {
            "PHPdot\\Cache\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PHPdot\\Cache\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "analyse": "phpstan analyse --memory-limit=256M",
        "cs-fix": "php-cs-fixer fix",
        "cs-check": "php-cs-fixer fix --dry-run --diff",
        "check": [
            "@test",
            "@analyse",
            "@cs-check"
        ]
    },
    "config": {
        "sort-packages": true
    }
}
